    "dotenv": "^11.0.0",
    "express": "^4.22.1",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^8.5.1",
    "mongodb": "^7.1.1",
    "mongoose": "^9.3.2"
  },
  "devDependencies": {
    "nodemon": "^2.0.15"
  }
}
